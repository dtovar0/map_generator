# Integración local con Cacti (recomendado: usuario MySQL de sólo lectura)
CACTI_ENABLED=true
# Fuente de métricas: "rrd" lee los archivos directamente; "db" usa mapgen_rrd_samples.
CACTI_METRICS_SOURCE=rrd
CACTI_DB_HOST=127.0.0.1
CACTI_DB_PORT=3306
CACTI_DB_NAME=cacti
CACTI_DB_USER=cacti_map_reader
CACTI_DB_PASSWORD=change-me

# Para socket local, descomenta esta línea; tiene prioridad sobre host/puerto.
# CACTI_DB_SOCKET=/run/mysqld/mysqld.sock

# Uno o más directorios RRD separados por comas.
CACTI_RRD_PATH=/var/lib/cacti/rra
CACTI_RRDTOOL=/usr/bin/rrdtool
CACTI_CACHE_SECONDS=30

# Colector Python
# Ruta relativa a la raíz de map_generator. El colector la crea si no existe.
MAPGEN_MAPS_DIR=data/maps
MAPGEN_METRICS_RETENTION_DAYS=400
MAPGEN_COLLECTOR_LOCK=/tmp/mapgen-cacti-collector.lock

# Base de datos propia de la app (usuarios, sesiones y mapas guardados).
# MAPGEN_DB_HOST=127.0.0.1
# MAPGEN_DB_PORT=3306
# MAPGEN_DB_USER=mapgen
# MAPGEN_DB_PASSWORD=change-me
# MAPGEN_DB_NAME=mapgen
# Para socket local, descomenta esta línea; tiene prioridad sobre host/puerto.
# MAPGEN_DB_SOCKET=/run/mysqld/mysqld.sock

# Autenticación: modos combinables (local, forward-auth de Authelia, OIDC de Authelia).
# AUTH_LOCAL_ENABLED=true
# AUTH_FORWARD_ENABLED=false
# AUTH_OIDC_ENABLED=false
# AUTH_OIDC_ISSUER=https://auth.ejemplo.com
# AUTH_OIDC_CLIENT_ID=mapgen
# AUTH_OIDC_CLIENT_SECRET=change-me
# Firma HMAC de la cookie temporal del flujo OIDC (obligatoria si AUTH_OIDC_ENABLED=true).
# AUTH_SESSION_SECRET=change-me

# Grupos de Authelia (separados por coma) que otorgan cada rol; rol por defecto si ninguno coincide.
# AUTH_ADMIN_GROUPS=mapgen-admins
# AUTH_EDITOR_GROUPS=mapgen-editors
# AUTH_DEFAULT_ROLE=viewer

# Vida de la sesión local (deslizante), en horas.
# AUTH_SESSION_TTL_HOURS=168

# Usuario admin a crear/promover automáticamente al arrancar si no hay ningún admin activo.
# AUTH_BOOTSTRAP_ADMIN_USER=admin
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me
